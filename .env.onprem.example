# ============ ANALYTIQ — ON-PREM ============
# Copy to .env and fill in. Used by docker-compose.onprem.yml
# Fully self-contained: local LLM (Ollama) + local embeddings. No cloud, no data egress.

DEPLOY_MODE=onprem

# --- LLM: local model served by the Ollama container ---
# after 'up', pull it once:  docker compose -f docker-compose.onprem.yml exec ollama ollama pull qwen2.5:14b-instruct
DEFAULT_MODEL=qwen2.5-14b
# LOCAL_LLM_BASE_URL is set by the compose file to http://ollama:11434/v1

# --- embeddings: local (sentence-transformers, baked into the on-prem image) ---
EMBEDDING_MODE=local

# --- data source ---
# database = customer points at their own DB (read-only role!)
# files    = customer drops CSV/Parquet in the mounted /data/files folder
# all      = merge DB + files + uploads
DATA_SOURCE=all
ENABLE_UPLOADS=1
# DB_URL=postgresql+psycopg2://readonly:pass@customer-db:5432/erp
# (mount data files via the compose 'volumes' block: /path:/data/files:ro)

# --- limits ---
SQL_ROW_LIMIT=5000
SCHEMA_TOP_K=6
