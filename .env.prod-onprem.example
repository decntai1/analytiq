# ============ ANALYTIQ — PRODUCTION ON-PREM (single-tenant, TLS, local LLM) ============
# Used by docker-compose.prod-onprem.yml
DEPLOY_MODE=onprem
MULTI_TENANT=0

# --- TLS: a domain the customer controls, or an internal name + their own cert ---
DOMAIN=analytiq.internal.company.com

# --- LLM runtime: 'ollama' (default, demo) or 'analytiq' (your runtime on this box) ---
LLM_RUNTIME=ollama
# For your runtime, set:
# LLM_RUNTIME=analytiq
# ANALYTIQ_RUNTIME_URL=http://analytiq-runtime:8000/v1

# --- LLM: local Ollama (pull after up) ---
DEFAULT_MODEL=qwen2.5-14b
EMBEDDING_MODE=local

# --- data: customer's own DB (read-only role!) or files on the box ---
DATA_SOURCE=all
# DB_URL=postgresql+psycopg2://readonly:pass@customer-db:5432/erp
ENABLE_UPLOADS=1
RATE_LIMIT_PER_MIN=120
MAX_UPLOAD_MB=100
