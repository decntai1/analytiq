# ============ ANALYTIQ — PRODUCTION SaaS (multi-tenant, TLS) ============
# Used by docker-compose.prod.yml
DEPLOY_MODE=cloud
MULTI_TENANT=1

# --- TLS / domain (Caddy auto-provisions Let's Encrypt for this domain) ---
DOMAIN=analytiq.example.com

# --- admin (required to create tenants via /admin/tenants) ---
ADMIN_TOKEN=change-me-to-a-long-random-string

# --- LLM ---
DEFAULT_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...
EMBEDDING_MODE=openai

# --- security ---
CORS_ORIGINS=https://app.example.com     # your frontend origin(s), comma-sep
RATE_LIMIT_PER_MIN=60
MAX_UPLOAD_MB=50

# --- data: tenants attach their own source; default for new tenants is 'upload' ---
DATA_SOURCE=upload

# --- durable app state — MUST live on the /data volume, not the container FS ---
# Dashboards (pinned tiles) and workbench sessions/recipes. The code default is a
# RELATIVE ./dashboards → /app/dashboards, which is the container's ephemeral layer
# and is WIPED on every `up --build` recreate (silently destroyed all pinned tiles
# until 2026-07-19). Keep these on /data so they survive redeploys.
DASHBOARD_DIR=/data/dashboards
WORKBENCH_DIR=/data/workbench

# --- accounts (user login: register/sign-in, saved chats, plan credits) ---
# SQLite file for users/sessions/conversations. Keep it on the persisted volume.
ACCOUNTS_DB=/data/accounts.db
# Set 1 in production (session cookie sent only over HTTPS — Caddy provides TLS).
COOKIE_SECURE=1

# --- billing (Stripe subscriptions; leave empty to disable billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ANALYST=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_BUSINESS=
PUBLIC_URL=https://analytiq.example.com
