# ============ ANALYTIQ — CLOUD / SaaS ============
# Copy to .env and fill in. Used by docker-compose.cloud.yml

DEPLOY_MODE=cloud

# --- LLM: which model answers by default (must be a name in MODEL_REGISTRY) ---
DEFAULT_MODEL=gpt-4o-mini
# keys for whichever cloud providers you enable:
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# XAI_API_KEY=xai-...

# --- embeddings: cloud uses OpenAI; needs OPENAI_API_KEY above ---
EMBEDDING_MODE=openai

# --- data source ---
# upload   = users upload files via the UI (good for the demo / SaaS trial)
# database = connect to a customer DB via DB_URL
# all      = merge DB + files + uploads
DATA_SOURCE=upload
ENABLE_UPLOADS=1
# DB_URL=postgresql+psycopg2://readonly:pass@host:5432/dbname

# --- limits / behaviour ---
SQL_ROW_LIMIT=5000
SCHEMA_TOP_K=6
